# yomotsusaka — environment variable reference
#
# Per issue #46 metaplan Fork 3, credentials and Pod identifiers are
# env-var-only. They are classified `never_expose` (architecture
# capability matrix): never logged, never echoed in exception messages,
# never returned in any agent-facing surface.
#
# Copy this file to `.env` and fill in real values **outside** version
# control. Do NOT commit a populated `.env`.

# ---------------------------------------------------------------------------
# vLLM backend (src/yomotsusaka/vllm_backend.py)
# ---------------------------------------------------------------------------

# Base URL of the vLLM OpenAI-compatible server. Required by
# scripts/smoke_runpod.py; may be supplied programmatically when calling
# VLLMBackend(endpoint=...) directly.
#
# Example (RunPod proxy):
#   VLLM_ENDPOINT=https://<pod-id>-8000.proxy.runpod.net
VLLM_ENDPOINT=

# Optional bearer token. If unset and RUNPOD_POD_ID is set, the backend
# falls back to `sk-<RUNPOD_POD_ID>` per docs/runpod.md §6. Absence of
# both is permitted only against a vLLM template that has API-key auth
# disabled.
VLLM_API_KEY=

# ---------------------------------------------------------------------------
# RunPod lifecycle (src/yomotsusaka/runpod_lifecycle.py)
# ---------------------------------------------------------------------------

# Mode selector for `lifecycle_from_env()`:
#   mock    — synthetic handle, no network. Default. Used by unit tests.
#   attach  — read RUNPOD_POD_ID / RUNPOD_POD_ENDPOINT; never create or
#             destroy a Pod. The only real-mode that must work for #46.
#   manage  — full RunPod GraphQL Pod lifecycle. NotImplementedError in
#             this PR; reserved for a follow-up issue with cost-control
#             wiring.
YOMOTSUSAKA_RUNPOD_MODE=mock

# Identifier of the owner-provisioned Pod. Required when
# YOMOTSUSAKA_RUNPOD_MODE=attach. Also used as the `sk-<pod-id>` fallback
# for VLLM_API_KEY.
RUNPOD_POD_ID=

# Base URL of the owner-provisioned Pod's vLLM endpoint. Required when
# YOMOTSUSAKA_RUNPOD_MODE=attach.
#
# Example (RunPod proxy): https://<pod-id>-8000.proxy.runpod.net
RUNPOD_POD_ENDPOINT=

# RunPod GraphQL API key. Only read in `manage` mode (NotImplementedError
# in this PR). Ignored in `mock` and `attach` modes.
RUNPOD_API_KEY=

# ---------------------------------------------------------------------------
# Smoke / live-test gates
# ---------------------------------------------------------------------------

# Set to `1` to allow scripts/smoke_runpod.py to actually hit a live
# vLLM endpoint. Absence (or any other value) makes the script refuse to
# run. Explicitly NOT a CI merge gate — cost control.
RUNPOD_LIVE_SMOKE=

# ---------------------------------------------------------------------------
# HTTP timeout overrides (optional)
# ---------------------------------------------------------------------------

# Override the 60 s default for POST /v1/chat/completions.
YOMOTSUSAKA_VLLM_REQUEST_TIMEOUT=

# Override the 5 s default for GET /health probes.
YOMOTSUSAKA_VLLM_HEALTH_TIMEOUT=
